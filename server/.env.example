# Server environment variables — copy to .env and fill values
PORT=8001
CLIENT_URL=http://localhost:5173

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=idle_db

# JWT Secrets — use long random strings in production!
JWT_SECRET=idle-super-secret-jwt-key-change-me-in-production
JWT_REFRESH_SECRET=idle-refresh-secret-key-change-me-in-production

# AI Microservice (Python FastAPI)
AI_SERVICE_URL=http://localhost:8002
